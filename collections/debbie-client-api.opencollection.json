{
  "opencollection": "1.0.0",
  "info": {
    "name": "Debbie Client API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Cases",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create a case",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://creditor.debbie.dk/api/cases"
          },
          "docs": "Create a case"
        },
        {
          "info": {
            "name": "Get a case",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://creditor.debbie.dk/api/cases/:caseId",
            "params": [
              {
                "name": "caseId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get a case"
        }
      ]
    },
    {
      "info": {
        "name": "Payments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Submit payment information",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://creditor.debbie.dk/api/cases/:caseId/payments",
            "params": [
              {
                "name": "caseId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Submit payment information"
        }
      ]
    }
  ],
  "bundled": true
}